// ============================================
// MORAKIB - Database Schema
// SOC Analyst Assistant Platform
// ============================================

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  ANALYST_JUNIOR
  ANALYST_SENIOR
  LEAD
  ADMIN
}

enum AlertSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum AlertStatus {
  NEW
  ASSIGNED
  INVESTIGATING
  RESOLVED
  ESCALATED
  FALSE_POSITIVE
}

enum AlertSource {
  SURICATA
  ZEEK
  FILEBEAT
  ELASTIC
  CUSTOM
}

enum InvestigationConclusion {
  TRUE_POSITIVE
  FALSE_POSITIVE
  NEEDS_ESCALATION
  INCONCLUSIVE
}

enum SOPStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SOPInstanceStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  VALIDATED
  ARCHIVED
}

enum TaskType {
  INVESTIGATE_ALERT
  REVIEW_SOP
  TRAINING
  OTHER
}

// ============================================
// MODELS
// ============================================

model User {
  id            String    @id @default(cuid())
  keycloakId    String?   @unique @map("keycloak_id")
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  name          String?
  image         String?
  role          UserRole  @default(ANALYST_JUNIOR)
  avatarUrl     String?   @map("avatar_url")
  teamId        String?   @map("team_id")
  team          Team?     @relation(fields: [teamId], references: [id])
  
  // NextAuth relations
  accounts      Account[]
  sessions      Session[]
  
  // App relations
  assignedAlerts  Alert[]         @relation("AssignedAlerts")
  investigations  Investigation[]
  createdSOPs     SOP[]           @relation("CreatedSOPs")
  tasks           Task[]
  metrics         AnalystMetric[]
  badges          UserBadge[]
  sopProgress     SOPProgress[]
  
  // SOP Instance relations
  createdSOPInstances   SOPInstance[] @relation("CreatedSOPInstances")
  mentoredSOPInstances  SOPInstance[] @relation("MentoredSOPs")
  validatedSOPInstances SOPInstance[] @relation("ValidatedSOPInstances")
  sopInstanceHistory    SOPInstanceHistory[] @relation("SOPInstanceHistoryEntries")
  
  // Guide Progress relations
  guideProgress         GuideProgress[]
  validatedGuides       GuideProgress[] @relation("ValidatedGuides")
  
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  
  @@map("users")
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  
  members     User[]
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@map("teams")
}

model Alert {
  id              String        @id @default(cuid())
  elasticsearchId String?       @unique @map("elasticsearch_id")
  title           String
  description     String?
  severity        AlertSeverity @default(MEDIUM)
  status          AlertStatus   @default(NEW)
  source          AlertSource   @default(SURICATA)
  
  // Alert details
  sourceIp        String?       @map("source_ip")
  destIp          String?       @map("dest_ip")
  sourcePort      Int?          @map("source_port")
  destPort        Int?          @map("dest_port")
  protocol        String?
  ruleName        String?       @map("rule_name")
  ruleId          String?       @map("rule_id")
  
  // Raw data
  rawLog          Json?         @map("raw_log")
  enrichmentData  Json?         @map("enrichment_data")
  
  // Assignment
  assignedToId    String?       @map("assigned_to_id")
  assignedTo      User?         @relation("AssignedAlerts", fields: [assignedToId], references: [id])
  assignedAt      DateTime?     @map("assigned_at")
  
  // Timestamps
  detectedAt      DateTime      @default(now()) @map("detected_at")
  resolvedAt      DateTime?     @map("resolved_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  
  // Relations
  investigations  Investigation[]
  tasks           Task[]
  
  @@index([status])
  @@index([severity])
  @@index([assignedToId])
  @@index([detectedAt])
  @@map("alerts")
}

model Investigation {
  id                String                   @id @default(cuid())
  alertId           String                   @map("alert_id")
  alert             Alert                    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  analystId         String                   @map("analyst_id")
  analyst           User                     @relation(fields: [analystId], references: [id])
  
  // SOP used
  sopId             String?                  @map("sop_id")
  sop               SOP?                     @relation(fields: [sopId], references: [id])
  
  // Investigation details
  checklistResults  Json?                    @map("checklist_results")
  findings          String?
  conclusion        InvestigationConclusion?
  actionsTaken      Json?                    @map("actions_taken")
  timeSpentMinutes  Int?                     @map("time_spent_minutes")
  
  // IRIS integration
  irisIncidentId    String?                  @map("iris_incident_id")
  
  // Timestamps
  startedAt         DateTime                 @default(now()) @map("started_at")
  completedAt       DateTime?                @map("completed_at")
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")
  
  @@index([alertId])
  @@index([analystId])
  @@map("investigations")
}

model SOP {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  category        String
  alertTypes      String[]  @map("alert_types")
  
  // Content
  contentMarkdown String    @map("content_markdown") @db.Text
  checklist       Json?
  examples        Json?
  
  // MITRE ATT&CK Framework
  mitreTactics     String[]  @default([]) @map("mitre_tactics")     // TA0001, TA0002, etc.
  mitreTechniques  String[]  @default([]) @map("mitre_techniques")  // T1566, T1059, etc.
  
  // Practical Guide
  elkQueries       Json?     @map("elk_queries")      // Array of {description, query}
  procedures       Json?     @map("procedures")       // Array of step-by-step procedures
  detection        Json?     @map("detection")        // Detection methods
  mitigation       Json?     @map("mitigation")       // Mitigation strategies
  dataSources      String[]  @default([]) @map("data_sources") // Required data sources
  
  // Metadata
  version         Int       @default(1)
  status          SOPStatus @default(DRAFT)
  severity        String?   @default("MEDIUM")        // LOW, MEDIUM, HIGH, CRITICAL
  estimatedTime   String?   @map("estimated_time")    // e.g., "30 min", "1-2 hours"
  
  // Author
  createdById     String    @map("created_by_id")
  createdBy       User      @relation("CreatedSOPs", fields: [createdById], references: [id])
  
  // Relations
  investigations  Investigation[]
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  @@index([category])
  @@index([status])
  @@map("sops")
}

model Task {
  id          String     @id @default(cuid())
  analystId   String     @map("analyst_id")
  analyst     User       @relation(fields: [analystId], references: [id])
  alertId     String?    @map("alert_id")
  alert       Alert?     @relation(fields: [alertId], references: [id])
  
  type        TaskType   @default(OTHER)
  title       String
  description String?
  priority    Int        @default(0)
  status      TaskStatus @default(PENDING)
  dueDate     DateTime?  @map("due_date")
  
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  completedAt DateTime?  @map("completed_at")
  
  @@index([analystId])
  @@index([status])
  @@map("tasks")
}

model AnalystMetric {
  id                    String   @id @default(cuid())
  analystId             String   @map("analyst_id")
  analyst               User     @relation(fields: [analystId], references: [id])
  date                  DateTime @db.Date
  
  alertsProcessed       Int      @default(0) @map("alerts_processed")
  avgResolutionTimeMin  Float?   @map("avg_resolution_time_min")
  truePositives         Int      @default(0) @map("true_positives")
  falsePositives        Int      @default(0) @map("false_positives")
  escalations           Int      @default(0)
  
  createdAt             DateTime @default(now()) @map("created_at")
  
  @@unique([analystId, date])
  @@index([date])
  @@map("analyst_metrics")
}

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  icon        String
  points      Int         @default(0)
  condition   Json        // JSON describing the condition to earn this badge
  
  users       UserBadge[]
  
  createdAt   DateTime    @default(now()) @map("created_at")
  
  @@map("badges")
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  badgeId   String   @map("badge_id")
  badge     Badge    @relation(fields: [badgeId], references: [id])
  earnedAt  DateTime @default(now()) @map("earned_at")
  
  @@unique([userId, badgeId])
  @@map("user_badges")
}

// ============================================
// Guide Progress Tracking - Suivi des TP guidés
// ============================================
model GuideProgress {
  id                   String    @id @default(cuid())
  userId               String    @map("user_id")
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  guideId              String    @map("guide_id")
  
  // Progress state
  currentStep          Int       @default(1) @map("current_step")
  totalSteps           Int       @map("total_steps")
  completedSteps       Int[]     @default([]) @map("completed_steps")
  completionPercentage Int       @default(0) @map("completion_percentage")
  
  // Checklist state per step
  checklistState       Json      @default("{}") @map("checklist_state")
  
  // Quiz/Exercise results
  quizResults          Json?     @map("quiz_results")
  exerciseResults      Json?     @map("exercise_results")
  
  // Time tracking
  startedAt            DateTime  @default(now()) @map("started_at")
  completedAt          DateTime? @map("completed_at")
  totalTimeSeconds     Int       @default(0) @map("total_time_seconds")
  
  // Status
  completed            Boolean   @default(false)
  score                Int?      // Final score if guide has quiz
  
  // Validation by mentor/lead
  validatedById        String?   @map("validated_by_id")
  validatedBy          User?     @relation("ValidatedGuides", fields: [validatedById], references: [id])
  validatedAt          DateTime? @map("validated_at")
  validationNotes      String?   @map("validation_notes") @db.Text
  
  // Timestamps
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  
  @@unique([userId, guideId])
  @@index([userId])
  @@index([guideId])
  @@index([completed])
  @@map("guide_progress")
}

// ============================================
// SOP Progress Tracking
// ============================================
model SOPProgress {
  id                   String   @id @default(cuid())
  userId               String   @map("user_id")
  user                 User     @relation(fields: [userId], references: [id])
  sopSlug              String   @map("sop_slug")
  
  // Progress state
  checklistState       Json     @default("{}") @map("checklist_state")
  activeStep           Int      @default(1) @map("active_step")
  completionPercentage Int      @default(0) @map("completion_percentage")
  
  // Time tracking
  startedAt            DateTime @default(now()) @map("started_at")
  completedAt          DateTime? @map("completed_at")
  elapsedSeconds       Int      @default(0) @map("elapsed_seconds")
  completed            Boolean  @default(false)
  
  // Timestamps
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  
  @@unique([userId, sopSlug])
  @@index([userId])
  @@index([sopSlug])
  @@map("sop_progress")
}

// ============================================
// SOP Instance - Suivi dynamique des SOPs remplis
// ============================================
model SOPInstance {
  id                String            @id @default(cuid())
  
  // SOP Template reference
  sopSlug           String            @map("sop_slug")
  sopTitle          String            @map("sop_title")
  sopVersion        String            @default("1.0") @map("sop_version")
  
  // Instance metadata
  title             String            // Ex: "Onboarding - Ahmed Bennani"
  reference         String            @unique // Ex: "SOP-OB-2026-001"
  
  // Subject info (la personne concernée par le SOP)
  subjectName       String            @map("subject_name")
  subjectEmail      String?           @map("subject_email")
  subjectRole       String?           @map("subject_role")
  subjectInfo       Json?             @map("subject_info") // Additional subject metadata
  
  // Mentor/Completer info
  mentorId          String?           @map("mentor_id")
  mentor            User?             @relation("MentoredSOPs", fields: [mentorId], references: [id])
  
  // Creator
  createdById       String            @map("created_by_id")
  createdBy         User              @relation("CreatedSOPInstances", fields: [createdById], references: [id])
  
  // Status & Progress
  status            SOPInstanceStatus @default(DRAFT)
  currentStep       Int               @default(1) @map("current_step")
  totalSteps        Int               @default(1) @map("total_steps")
  completionPercent Int               @default(0) @map("completion_percent")
  
  // Form data (all filled fields)
  formData          Json              @default("{}") @map("form_data")
  checklistState    Json              @default("{}") @map("checklist_state")
  notes             String?           @db.Text
  
  // Validation
  validatedById     String?           @map("validated_by_id")
  validatedBy       User?             @relation("ValidatedSOPInstances", fields: [validatedById], references: [id])
  validatedAt       DateTime?         @map("validated_at")
  validationNotes   String?           @map("validation_notes") @db.Text
  
  // Version control
  version           Int               @default(1)
  
  // Dates
  startedAt         DateTime?         @map("started_at")
  completedAt       DateTime?         @map("completed_at")
  dueDate           DateTime?         @map("due_date")
  
  // Relations
  history           SOPInstanceHistory[]
  
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  
  @@index([sopSlug])
  @@index([status])
  @@index([mentorId])
  @@index([createdById])
  @@index([subjectName])
  @@map("sop_instances")
}

// ============================================
// SOP Instance History - Historique des versions
// ============================================
model SOPInstanceHistory {
  id              String      @id @default(cuid())
  
  instanceId      String      @map("instance_id")
  instance        SOPInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  
  // Version info
  version         Int
  action          String      // "created", "updated", "completed", "validated", "step_completed"
  description     String?     // Human readable description of change
  
  // Who made the change
  userId          String      @map("user_id")
  user            User        @relation("SOPInstanceHistoryEntries", fields: [userId], references: [id])
  
  // Snapshot of data at this version
  formDataSnapshot   Json?    @map("form_data_snapshot")
  checklistSnapshot  Json?    @map("checklist_snapshot")
  statusBefore       String?  @map("status_before")
  statusAfter        String?  @map("status_after")
  
  // Changes made
  changes         Json?       // Detailed changes: {field: {old: x, new: y}}
  
  createdAt       DateTime    @default(now()) @map("created_at")
  
  @@index([instanceId])
  @@index([version])
  @@map("sop_instance_history")
}

